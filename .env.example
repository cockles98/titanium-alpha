# LLM provider (default: gemini)
# Use "gemini" for Google AI Studio (free tier, 500 req/day) or "anthropic" for Claude.
LLM_PROVIDER=gemini

# Override the default model per provider (optional).
# Defaults: gemini-3.1-flash-lite-preview (gemini) / claude-sonnet-4-6 (anthropic)
# LLM_MODEL=gemini-3.1-flash-lite-preview

# Gemini (Google AI) — required when LLM_PROVIDER=gemini
# Create at https://aistudio.google.com/app/apikey
GEMINI_KEY=your-gemini-api-key

# Anthropic — required when LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your-anthropic-api-key

# News ingestion (NewsAPI) — required for `make ingest` to populate RAG
# Create at https://newsapi.org/register
NEWSAPI_KEY=your-newsapi-key

# PostgreSQL (OHLCV + news persistence)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=titanium_alpha
POSTGRES_USER=titanium
POSTGRES_PASSWORD=changeme

# ChromaDB (vector store for RAG)
CHROMA_HOST=localhost
CHROMA_PORT=8000
